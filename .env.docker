# Docker Compose 环境变量
# 复制为 .env 并按需修改

# 访问地址
APP_URL=http://localhost:8080

# 数据库
MYSQL_ROOT_PASSWORD=root_secret_change_me
DB_NAME=card_auth
DB_USER=card_auth
DB_PASS=card_auth_pass

# JWT 密钥（留空则自动生成随机密钥，但容器重启会变）
# 生成方式: openssl rand -base64 48
JWT_SECRET=

# 支付（可选）
PAYMENT_TYPE=epay
PAYMENT_API_URL=
PAYMENT_APP_ID=
PAYMENT_APP_KEY=
